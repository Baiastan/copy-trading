# Copy this file to .env and fill in your values

# Webull developer API credentials (from developer.webull.com)
WEBULL_APP_KEY=your_app_key_here
WEBULL_APP_SECRET=your_app_secret_here

# Your Webull account IDs — run step2_test.py to find these
WEBULL_ACCOUNT_IDS=ACCOUNT_ID_1,ACCOUNT_ID_2
WEBULL_DEFAULT_ACCOUNT_ID=ACCOUNT_ID_1

# Firebase (get URL from Firebase console, credentials JSON from Service Accounts)
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# Copy settings
SIZE_MULTIPLIER=1.0
POLL_INTERVAL=5
SIGNAL_MAX_AGE_SECONDS=60
